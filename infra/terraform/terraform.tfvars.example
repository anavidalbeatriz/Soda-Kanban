# Copy to terraform.tfvars and fill in sensitive values.
# Do not commit terraform.tfvars.

aws_region    = "us-east-1"
project_name  = "soda-kanba"
environment   = "prod"

ses_domain     = "kfsoda.tech"
ses_from_email = "gabriel@kfsoda.tech"

# Optional: custom domain (requires route53_zone_id)
# domain_name     = "app.example.com"
# route53_zone_id = "Z1234567890"

# Optional: GitHub OIDC deploy role (org/repo format)
# github_repository = "your-org/soda-kanba"

# Set after first apply if not using a custom domain:
# frontend_url = "https://d1234abcd.cloudfront.net"

# Sensitive — pass via CLI or environment instead of committing:
# database_password = "..."
# jwt_secret        = "..."
