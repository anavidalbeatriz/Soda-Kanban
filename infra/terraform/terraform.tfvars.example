# Copy to terraform.tfvars and fill in sensitive values.
# Do not commit terraform.tfvars.

aws_region    = "us-east-1"
project_name  = "soda-kanba"
environment   = "prod"

ses_domain     = "kfsoda.tech"
ses_from_email = "gabriel@kfsoda.tech"

# Custom app URL — add sodakanban subdomain in HostGator DNS (see infra/terraform/README.md)
domain_name  = "sodakanban.kfsoda.tech"
frontend_url = "https://sodakanban.kfsoda.tech"

# Optional: use Route 53 instead of HostGator for DNS (auto-manages ACM + alias records)
# route53_zone_id = "Z1234567890"

# GitHub OIDC deploy role (org/repo format) — must match the repo running CI
github_repository = "gabrielvidalsoda/Soda-Kanban"

# Set after first apply if not using a custom domain:
# frontend_url = "https://d1234abcd.cloudfront.net"
# Or with custom domain:
# domain_name  = "sodakanban.kfsoda.tech"
# frontend_url = "https://sodakanban.kfsoda.tech"

# Sensitive — pass via CLI or environment instead of committing:
# database_password = "..."
# jwt_secret        = "..."
